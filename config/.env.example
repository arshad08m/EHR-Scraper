# ─────────────────────────────────────────────────────────────────────────────
# Kantime WorldView Scraper — Environment Configuration Template
# Copy this file to config/.env and fill in real values.
# NEVER commit config/.env to git.
# ─────────────────────────────────────────────────────────────────────────────

# Kantime login credentials
KANTIME_USERNAME=your-email@example.com
KANTIME_PASSWORD=your-password

# Kantime URLs (defaults are correct for Z1 tenant — change only if different)
KANTIME_BASE_URL=https://www.kantimehealth.net/HH/Z1
KANTIME_LOGIN_URL=https://www.kantimehealth.net/identity/v2/Accounts/Authorize?product=hh
KANTIME_WORLDVIEW_URL=https://www.kantimehealth.net/HH/Z1/UI/Orders/WorldView_ReceivedDocuments.aspx

# MongoDB Atlas (leave blank to use local JSONL output instead)
MONGO_CONNECTION_STRING=
MONGO_DB_NAME=kantime_ehr
MONGO_COLLECTION=orders

# Scraper behavior
REQUEST_DELAY_SECONDS=1.5
MAX_RETRIES=3
MAX_DOCS=0
ENABLE_DATA_EXTRACTION=false

# Ollama vision extraction (active only when BOTH flags are true)
OLLAMA_ENABLED=false
OLLAMA_MODEL=qwen2.5vl:7b
OLLAMA_URL=http://localhost:11434
OLLAMA_TIMEOUT_SECONDS=90
OLLAMA_MAX_PAGES=2
